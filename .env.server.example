## Docker server/prod env template
## Copy: cp .env.server.example .env

# Public web port on host (nginx in container listens on 80)
WEB_PORT=80

# If app runs under subpath, set both to same value (must end with slash)
# Example: /posting/agent-base/
VITE_BASE_PATH=/
VITE_API_URL=/api

# Optional: force browser requests to canonical host/scheme
# Example: https://agentbase.boximgs.com
APP_CANONICAL_URL=

# API/worker
USE_CELERY=true
CELERY_WORKER_CONCURRENCY=4
REDIS_URL=redis://redis:6379/0

# Media URLs (browser side)
# If behind reverse proxy/domain, put final public base URL
# Example: https://example.com
MEDIA_PUBLIC_BASE_URL=http://localhost

# MySQL for containerized stack
AGENTBASE_MYSQL_ROOT_PASSWORD=change_me_root
AGENTBASE_MYSQL_DATABASE=agentbase
AGENTBASE_MYSQL_USER=agentbase
AGENTBASE_MYSQL_PASSWORD=change_me_db

# Optional: external DB URL override (if set, compose uses this)
# DOCKER_DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname
